{
  "name": "@nestarc/webhook",
  "version": "0.6.0",
  "description": "Outbound webhook delivery for NestJS — HMAC signing, exponential retry, circuit breaker, delivery logs, fan-out, Standard Webhooks compatible",
  "author": "nestarc",
  "license": "MIT",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "src/sql"
  ],
  "scripts": {
    "clean": "rm -rf dist",
    "build": "tsc -p tsconfig.build.json",
    "test": "jest",
    "test:e2e": "jest --config jest.e2e.config.js --runInBand",
    "test:cov": "jest --coverage --runInBand",
    "lint": "tsc --noEmit",
    "prisma:generate": "prisma generate --schema=test/e2e/schema.prisma",
    "prepublishOnly": "npm run clean && npm run lint && npm test && npm run build"
  },
  "peerDependencies": {
    "@nestjs/common": "^10.0.0 || ^11.0.0",
    "@nestjs/core": "^10.0.0 || ^11.0.0",
    "@nestjs/schedule": "^4.0.0 || ^5.0.0",
    "@prisma/client": "^5.0.0 || ^6.0.0"
  },
  "devDependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/schedule": "^5.0.0",
    "@nestjs/testing": "^11.0.0",
    "@prisma/client": "^6.0.0",
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "jest": "^29.7.0",
    "prisma": "^6.19.3",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.0",
    "ts-jest": "^29.2.0",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/nestarc/webhook.git"
  },
  "keywords": [
    "nestjs",
    "webhook",
    "outbound",
    "hmac",
    "retry",
    "circuit-breaker",
    "standard-webhooks"
  ]
}
